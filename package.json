{
  "name": "feetrack-monorepo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "stop:ports": "npx kill-port 3001 5173 >nul 2>&1 || exit 0",
    "dev": "npm run stop:ports && npx concurrently -k -n client,server -c blue,green \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "vite",
    "dev:server": "npm --prefix server run dev",
    "build": "vite build",
    "preview": "vite preview",
    "start": "npm --prefix server start"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.42.0",
    "@tanstack/react-query": "^5.0.0",
    "axios": "^1.6.7",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.4.1",
    "react-router-dom": "^6.23.1",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.27",
    "concurrently": "^8.2.2",
    "kill-port": "^2.0.1",
    "nodemon": "^3.1.14",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "vite": "^5.4.0"
  }
}
